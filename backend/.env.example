NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/shopsphere
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
PLATFORM_TIMEOUT_MS=12000

# Optional Amazon PA-API credentials
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_MARKETPLACE=www.amazon.in

# Optional Amazon RapidAPI fallback
AMAZON_RAPIDAPI_KEY=
AMAZON_RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com

# Required when using puppeteer-core (Windows example)
PUPPETEER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
